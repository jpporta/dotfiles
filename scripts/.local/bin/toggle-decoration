#!/usr/bin/env bash
# Toggle Hyprland decoration profile between "blur" and "flat".
# State is persisted in ~/.local/state/hypr-look and read by hyprland/look.lua.

set -euo pipefail

state_dir="$HOME/.local/state"
state_file="$state_dir/hypr-look"

mkdir -p "$state_dir"

current="blur"
if [[ -f "$state_file" ]]; then
    current="$(<"$state_file")"
fi

if [[ "$current" == "flat" ]]; then
    echo "blur" > "$state_file"
else
    echo "flat" > "$state_file"
fi

hyprctl reload >/dev/null
