#! /usr/bin/env bash

calendars=$(khal printcalendars)
last_end_time=$(khal list "$(date +%F) 00:00" "$(date +%F\ %R)" -f {end-time} | tail -1)

if [[ -z $last_end_time ]]; then
		last_end_time="07:00"
fi

description="$2"
for i in "${@:3}"; do
	description="$description $i"
done

if [[ -z $description ]]; then
	echo "Please provide a description for the event."
	exit 1
fi

if [[ -z $1 ]]; then

	echo "Please provide a partial name of the calendar."
	exit 1
fi

filtered_calendars=$(echo -e "$calendars" | grep -i "$1")
if [[ -z $filtered_calendars ]]; then
			filtered_calendars=$calendars
fi
if [[ $(echo "$filtered_calendars" | wc -l) -eq 1 ]]; then
selected_calendar=$(echo "$filtered_calendars" | awk '{print $1}')
else
echo "Multiple calendars found. Please select one:"
select selected_calendar in $filtered_calendars; do
	if [[ -n $selected_calendar ]]; then
		break
	else
		echo "Invalid selection. Please try again."
	fi
done
fi

khal new -a $selected_calendar $last_end_time $(date +%R) "$description"
