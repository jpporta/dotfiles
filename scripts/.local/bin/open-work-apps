#!/usr/bin/env bash

if [[ -z $(pgrep -x "obsidian") ]]
then
				obsidian & disown
fi

if [[ -z $(pgrep -x "slack") ]]
then
				slack  & disown
fi
if [[ -z $(pgrep -x "zen-browser") ]]
then
				zen-browser  & disown
fi
if [[ -z $(pgrep -x "kitty") ]]
then
				kitty  & disown
fi

sleep 4

hyprctl dispatch movetoworkspacesilent 1,class:zen-browser
hyprctl dispatch movetoworkspacesilent 2,class:slack
hyprctl dispatch movetoworkspacesilent 4,class:obsidian
hyprctl dispatch movetoworkspacesilent special:magic,class:kitty
